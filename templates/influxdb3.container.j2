{# Managed by Ansible — metrics-aggregation role. Do not edit manually. #}
{# Instance: {{ influxdb3_instance_name }} #}
[Unit]
Description=InfluxDB 3 Core — instance {{ influxdb3_instance_name }}
After=network-online.target influxdb3-{{ influxdb3_instance_name }}-volume.service {{ influxdb3_shared_network_name }}-network.service
Requires=influxdb3-{{ influxdb3_instance_name }}-volume.service {{ influxdb3_shared_network_name }}-network.service

[Container]
Image={{ influxdb3_image }}
ContainerName=influxdb3-{{ influxdb3_instance_name }}
Volume=influxdb3-{{ influxdb3_instance_name }}.volume:/var/lib/influxdb3:Z
Network={{ influxdb3_shared_network_name }}.network
EnvironmentFile={{ influxdb3_env_file_path | expanduser }}
PublishPort=127.0.0.1:{{ influxdb3_port }}:{{ influxdb3_port }}
# Disable auth on health/ping so Traefik and monitoring tools can probe without a token
Exec=influxdb3 serve --disable-authz health,ping

# Traefik discovery labels
Label=traefik.enable=true
Label=traefik.http.routers.influxdb3-{{ influxdb3_instance_name }}.rule=Host(`{{ influxdb3_hostname }}`)
Label=traefik.http.routers.influxdb3-{{ influxdb3_instance_name }}.entrypoints={{ influxdb3_traefik_entrypoint }}
Label=traefik.http.routers.influxdb3-{{ influxdb3_instance_name }}.tls=true
Label=traefik.http.services.influxdb3-{{ influxdb3_instance_name }}.loadbalancer.server.port={{ influxdb3_port }}

[Service]
Restart=on-failure
RestartSec=5s
TimeoutStartSec={{ influxdb3_startup_timeout_seconds }}

[Install]
WantedBy=default.target
